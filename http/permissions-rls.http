################################################################################
# Aether-Web — Banco de pruebas de PERMISOS y RLS
#
# Objetivo: dejar fijadas las comprobaciones de la allow-list por ruta y del
# aislamiento por escuadrilla (RLS), que de otro modo se verifican a mano por la
# UI con riesgo de olvidar un caso.
#
# Cómo usarlo:
#   1. Rellena http-client.private.env.json con usuarios/contraseñas reales de
#      cada nivel (ese archivo está gitignorado: NO subas credenciales).
#   2. Selecciona el entorno "dev" (esquina sup. derecha al ejecutar).
#   3. Ejecuta de arriba a abajo. Cada login captura su cookie de sesión en una
#      variable distinta (opCookie / admCookie / suCookie / comunCookie), así
#      podemos mantener VARIAS identidades a la vez en el mismo archivo y enviar
#      la cabecera Cookie de forma explícita por petición.
#
# Recordatorio de la allow-list (CLAUDE.md): NO hay jerarquía salvo Superusuario.
#   - Vuelos, slips, eventos, lookups de vuelo .......... Operacional
#   - Personal, comisiones, festivos .................... Administrativo
#   - Ausencias, ratings ............................... Operacional o Administrativo
#   - Credenciales y nivel de permiso (panel superuser) . Superusuario
#   - Lecturas (GET) ................................... cualquier autenticado
#   - Superusuario bypassa permisos PERO NO el RLS por escuadrilla.
################################################################################


### ───────────────────────────────────────────────────────────────────────────
### LOGINS — cada uno guarda su cookie en una variable global propia
### ───────────────────────────────────────────────────────────────────────────

### Login OPERACIONAL
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{ "user": "{{opUser}}", "password": "{{opPass}}" }

> {%
    client.test("operacional: login 200", () => {
        client.assert(response.status === 200, "esperaba 200, fue " + response.status);
    });
    // Set-Cookie viene como "aether_session=TOKEN; Path=/; HttpOnly; ...".
    // Nos quedamos solo con "aether_session=TOKEN".
    const sc = response.headers.valueOf("Set-Cookie");
    if (sc) client.global.set("opCookie", sc.split(";")[0]);
    client.test("operacional: nivel correcto", () => {
        client.assert(response.body.permissionLevel === "Operacional",
            "nivel inesperado: " + response.body.permissionLevel);
    });
%}

### Login ADMINISTRATIVO
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{ "user": "{{admUser}}", "password": "{{admPass}}" }

> {%
    client.test("administrativo: login 200", () => {
        client.assert(response.status === 200, "esperaba 200, fue " + response.status);
    });
    const sc = response.headers.valueOf("Set-Cookie");
    if (sc) client.global.set("admCookie", sc.split(";")[0]);
%}

### Login COMÚN (sin permisos de escritura)
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{ "user": "{{comunUser}}", "password": "{{comunPass}}" }

> {%
    client.test("comun: login 200", () => {
        client.assert(response.status === 200, "esperaba 200, fue " + response.status);
    });
    const sc = response.headers.valueOf("Set-Cookie");
    if (sc) client.global.set("comunCookie", sc.split(";")[0]);
%}

### Login SUPERUSUARIO (god-mode: bypassa permisos, NO el RLS)
POST {{baseUrl}}/api/v1/auth/login
Content-Type: application/json

{ "user": "{{suUser}}", "password": "{{suPass}}" }

> {%
    client.test("superusuario: login 200", () => {
        client.assert(response.status === 200, "esperaba 200, fue " + response.status);
    });
    const sc = response.headers.valueOf("Set-Cookie");
    if (sc) client.global.set("suCookie", sc.split(";")[0]);
%}


### ───────────────────────────────────────────────────────────────────────────
### CASO 1 — Sin sesión: toda escritura debe ser 401 (no 403)
### ───────────────────────────────────────────────────────────────────────────

### POST /persons sin cookie -> 401
POST {{baseUrl}}/api/v1/persons
Content-Type: application/json

{ "person_user": "noimporta" }

> {%
    client.test("sin sesion: 401", () => {
        client.assert(response.status === 401, "esperaba 401, fue " + response.status);
    });
%}


