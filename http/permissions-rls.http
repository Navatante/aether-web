### ───────────────────────────────────────────────────────────────────────────
### CASO 6 — GOD-MODE bypassa permisos: Superusuario puede escribir personal
###          (que normalmente es Administrativo) sin ser Administrativo
### ───────────────────────────────────────────────────────────────────────────

### POST /persons como SUPERUSUARIO -> pasa el permiso (no 401/403)
POST {{baseUrl}}/api/v1/persons
Content-Type: application/json
Cookie: {{suCookie}}

{ "person_user": "test.su" }

> {%
    client.test("superusuario bypassa el permiso de personal (no 401/403)", () => {
        client.assert(response.status !== 401 && response.status !== 403,
            "god-mode debería pasar el guard: " + response.status);
    });
%}


### ───────────────────────────────────────────────────────────────────────────
### CASO 7 — RLS por escuadrilla: god-mode NO la rompe
###
### El panel superuser opera SOLO sobre la escuadrilla de la sesión. Un :id de
### persona de OTRA escuadrilla debe dar 404 (no encontrado bajo el filtro RLS),
### nunca permitir la operación. Pon en {{otherEscPersonId}} un id real de otra
### escuadrilla; si no tienes uno a mano, déjalo y este test quedará informativo.
### ───────────────────────────────────────────────────────────────────────────

### PUT /superuser/persons/:id/password sobre persona de OTRA escuadrilla -> 404
PUT {{baseUrl}}/api/v1/superuser/persons/{{otherEscPersonId}}/password
Cookie: {{suCookie}}

> {%
    client.test("RLS: superuser no toca otra escuadrilla (404)", () => {
        client.assert(response.status === 404,
            "esperaba 404 por RLS, fue " + response.status +
            " (revisa que otherEscPersonId sea de OTRA escuadrilla)");
    });
%}


### ───────────────────────────────────────────────────────────────────────────
### CASO 8 — Salvaguarda: no degradar al último Superusuario de la escuadrilla
###
### Cambiar el nivel del único Superusuario de la escuadrilla debe dar 409.
### Pon en {{lastSuPersonId}} el id de ESE superusuario.
### ───────────────────────────────────────────────────────────────────────────

### PATCH nivel del último Superusuario -> 409 (ErrLastSuperuser)
PATCH {{baseUrl}}/api/v1/superuser/persons/{{lastSuPersonId}}/permission-level
Content-Type: application/json
Cookie: {{suCookie}}

{ "permissionLevel": "Común" }

> {%
    client.test("no se puede degradar al último superuser: 409", () => {
        client.assert(response.status === 409,
            "esperaba 409, fue " + response.status);
    });
%}


### ───────────────────────────────────────────────────────────────────────────
### CASO 9 — END-TO-END de FLIGHTS (Operacional): crear → leer → borrar
###
### Requiere ids REALES de tu DB local en el entorno (ver http-client.env.json):
###   depPlaceId, arrPlaceId  -> lookups/departure-arrival-places
###   aircraftId              -> lookups/aircrafts (de tu escuadrilla)
###   eventId                 -> lookups/events
###   pilotPersonSk           -> person_sk de un piloto de tu escuadrilla
### El POST es transaccional (~12 tablas hijas) y dispara tr_audit_flight.
### ───────────────────────────────────────────────────────────────────────────

### 9.1 — Crear vuelo como OPERACIONAL -> 201, captura flight_id
POST {{baseUrl}}/api/v1/flights
Content-Type: application/json
Cookie: {{opCookie}}

{
  "general": {
    "date": "2026-06-21",
    "departurePlace": {{depPlaceId}},
    "departureTime": "09:00",
    "arrivalPlace": {{arrPlaceId}},
    "arrivalTime": "10:30",
    "aircraft": {{aircraftId}},
    "event": {{eventId}},
    "totalHours": "1.5"
  },
  "pilots": [
    {
      "name": {{pilotPersonSk}},
      "person_hour": { "hDay": "1.5", "hNight": "0", "hGvn": "0" },
      "ift_hour": "0",
      "gvnType_hour": { "hIit": "0", "hAnvis": "0" },
      "instructor_hour": "0",
      "formation_hour": { "hfDay": "0", "hfGvn": "0" },
      "app": { "precision": "0", "noPrecision": "0", "td": "0", "sp": "0" },
      "landing": {
        "tierra":  { "lDay": "1", "lNight": "0", "lGvn": "0" },
        "mono":    { "lDay": "0", "lNight": "0", "lGvn": "0" },
        "multi":   { "lDay": "0", "lNight": "0", "lGvn": "0" },
        "carrier": { "lDay": "0", "lNight": "0", "lGvn": "0" }
      }
    }
  ],
  "dvs": [],
  "papeletas": [],
  "cupos": [],
  "capbas": [],
  "pasajeros": []
}

> {%
    client.test("crear vuelo: 201", () => {
        client.assert(response.status === 201, "esperaba 201, fue " + response.status +
            " | body: " + JSON.stringify(response.body));
    });
    if (response.body && response.body.flight_id) {
        client.global.set("e2eFlightId", response.body.flight_id);
    }
    client.test("crear vuelo: success=true", () => {
        client.assert(response.body.success === true, "success no es true");
    });
%}

### 9.2 — Leer el vuelo recién creado (filtrando por flight_sk) -> 200, aparece
GET {{baseUrl}}/api/v1/flights?flight_sk={{e2eFlightId}}
Cookie: {{opCookie}}

> {%
    client.test("leer vuelo creado: 200", () => {
        client.assert(response.status === 200, "esperaba 200, fue " + response.status);
    });
    client.test("leer vuelo creado: aparece en el listado", () => {
        client.assert(response.body.total_count >= 1 && response.body.items.length >= 1,
            "no se encontró el vuelo creado");
        client.assert(String(response.body.items[0].id) === client.global.get("e2eFlightId"),
            "el id del listado no coincide con el creado");
    });
%}

### 9.3 — Borrar el vuelo como OPERACIONAL -> 204
DELETE {{baseUrl}}/api/v1/flights/{{e2eFlightId}}
Cookie: {{opCookie}}

> {%
    client.test("borrar vuelo: 204", () => {
        client.assert(response.status === 204, "esperaba 204, fue " + response.status);
    });
%}

### 9.4 — Confirmar que ya no existe -> 200 con listado vacío
GET {{baseUrl}}/api/v1/flights?flight_sk={{e2eFlightId}}
Cookie: {{opCookie}}

> {%
    client.test("vuelo borrado: ya no aparece", () => {
        client.assert(response.status === 200, "esperaba 200, fue " + response.status);
        client.assert(response.body.total_count === 0 && response.body.items.length === 0,
            "el vuelo sigue apareciendo tras el borrado");
    });
%}

### 9.5 — Borrar de nuevo el mismo id -> 404 (ya no existe)
DELETE {{baseUrl}}/api/v1/flights/{{e2eFlightId}}
Cookie: {{opCookie}}

> {%
    client.test("borrar vuelo inexistente: 404", () => {
        client.assert(response.status === 404, "esperaba 404, fue " + response.status);
    });
%}


