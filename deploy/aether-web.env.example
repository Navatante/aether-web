# /etc/aether-web/env
#
# Variables de entorno consumidas por el binario aether-web.
# Permisos esperados: 0600, root:aether.

# DSN de PostgreSQL. Formato pgx (postgres://user:pass@host:port/db?sslmode=...).
AETHER_DATABASE_URL=postgres://aether_app:CHANGEME@127.0.0.1:5432/aether?sslmode=disable

# Dirección y puerto del HTTP. Sin host = 0.0.0.0.
AETHER_ADDR=:8080

# TTL de sesión. Acepta duración Go ("8h", "12h30m") o segundos ("28800").
AETHER_SESSION_TTL=8h

# Marca la cookie de sesión como Secure (solo viaja por HTTPS).
# Activar cuando la app esté detrás de TLS.
#AETHER_COOKIE_SECURE=true
